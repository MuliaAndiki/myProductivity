generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String?        @unique
  password      String?
  phone         String?        @unique
  token         String?
  role          RoleType
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  otp           String?
  expOtp        DateTime?
  isVerify      Boolean        @default(false)
  activateToken String?
  activateExp   DateTime?
  first_name    String
  last_name     String
  username      String?
  home          Home[]
  subscription  Subscription[]
  session       UserSession[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userAgent String
  createdAt DateTime @default(now())
  expiresAt DateTime
  ipAddress String
  userID    String
  user      User     @relation(fields: [userID], references: [id])

  @@index([userID])
  @@map("user_sessions")
}

model Subscription {
  id                   String             @id @default(uuid())
  userID               String
  plan                 PlanType
  status               StatusSubscription
  current_period_start DateTime           @default(now())
  current_period_end   DateTime
  createdAt            DateTime           @default(now())
  user                 User               @relation(fields: [userID], references: [id])

  @@index([userID])
  @@map("Subscription")
}

model Home {
  id         String   @id @default(uuid())
  userID     String
  latitude   Float
  longtitude Float
  city       String
  country    String
  radius     Int
  createdAt  DateTime @default(now())
  device     Device[]
  user       User     @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID])
  @@map("Home")
}

model MlModel {
  id        String   @id @default(uuid())
  name      String
  version   String
  modelPath String
  metrics   Json?
  isActive  Boolean
  createdAt DateTime @default(now())

  @@map("MlModel")
}

model Device {
  id               String          @id @default(uuid())
  homeID           String
  status           StatusDevice
  firmware_version String
  last_ping        DateTime
  createdAt        DateTime        @default(now())
  accesPoint       AccessPoint[]
  home             Home            @relation(fields: [homeID], references: [id], onDelete: Cascade)
  session          DeviceSession[]

  @@index([homeID])
  @@map("Device")
}

model AccessPoint {
  id        String           @id @default(uuid())
  deviceID  String
  room_name String
  status    AccesPointStatus
  device    Device           @relation(fields: [deviceID], references: [id], onDelete: Cascade)

  @@index([deviceID])
  @@map("AccesPoint")
}

model DeviceSession {
  id                String   @id @default(uuid())
  deviceID          String
  total_tokens_used Int
  createdAt         DateTime
  expires_at        DateTime
  device            Device   @relation(fields: [deviceID], references: [id], onDelete: Cascade)

  @@index([deviceID])
  @@map("DeviceSession")
}

enum RoleType {
  user
  developer
}

enum StatusDevice {
  online
  offline
}

enum PlanType {
  monthly
  yearly
}

enum AccesPointStatus {
  activate
  nonactivate
}

enum StatusSubscription {
  active
  past_due
  canceled
}
