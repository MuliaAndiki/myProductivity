generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String?       @unique
  password      String?
  phone         String?       @unique
  token         String?
  role          RoleType
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  otp           String?
  expOtp        DateTime?
  isVerify      Boolean       @default(false)
  activateToken String?
  activateExp   DateTime?
  first_name    String
  last_name     String
  session       UserSession[]
  category Category[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  userAgent String
  createdAt DateTime @default(now())
  expiresAt DateTime
  ipAddress String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_sessions")
}

model Category {
  id String @id @default(uuid())
  userId String
  title String
  desc String
  avatarCategoryUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  user User @relation(fields: [userId],references: [id])
  @@index([userId])
  @@map("Category")
}




enum RoleType {
  USER
  ADMIN
}
